# Copy to .env and fill in values:  cp .env.example .env

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_SERVER_SELECTION_MS=5000
MONGO_DB=ld_backend
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin

# Seedance / Volcengine Ark (required for /api/video/*)
ARK_API_KEY=
SEEDANCE_MODEL_ID=doubao-seedance-2-0-fast-260128
SEEDANCE_DURATION=4
SEEDANCE_RATIO=3:4
SEEDANCE_RESOLUTION=480p
SEEDANCE_WATERMARK=false
SEEDANCE_GENERATE_AUDIO=false

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_DAYS=7
MAX_PET_IMAGE_CHARS=2500000

# Server / inference
PORT=5000
LOG_LEVEL=INFO
STRIDE=25
VIDEO_POLL_INTERVAL_SECONDS=30
VIDEO_STORAGE_DIR=
CLOUD_RESULT_WS_ENABLED=true
CLOUD_RESULT_WS_HOST=8.156.34.152
CLOUD_RESULT_WS_PORT=4535
CLOUD_RESULT_WS_URL=
CLOUD_RESULT_WS_RECONNECT_SECONDS=3

# MODEL_DIR=
